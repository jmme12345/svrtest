{
  "name": "svrtest-dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "git.autofetch": true,
        "git.autoStash": true
      },
      "extensions": [
        "eamodio.gitlens",
        "ms-vscode.extension-pack-for-java"
      ]
    }
  },
  "postCreateCommand": "git config --global user.email 'user@example.com' && git config --global user.name 'User' && echo 'Codespace ready!'",
  "remoteUser": "codespace"
}
